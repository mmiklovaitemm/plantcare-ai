# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Local development (Vite dev server) ---
# These VITE_ keys are read by the browser and used via the Vite dev proxy.
VITE_PERENUAL_API_KEY=your-perenual-key
VITE_PLANTNET_API_KEY=your-plantnet-key
VITE_GEMINI_API_KEY=your-gemini-key

# --- Production (Vercel) ---
# In production these APIs are proxied through the serverless functions in
# /api, which read the keys below. Set these WITHOUT the VITE_ prefix so they
# stay on the server and are never exposed in the browser bundle. (The
# functions fall back to the VITE_ names above if these are unset.)
PLANTNET_API_KEY=your-plantnet-key
PERENUAL_API_KEY=your-perenual-key
GEMINI_API_KEY=your-gemini-key
